APP_NAME="GEDCO SSO"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_SA

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database (MySQL via XAMPP)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=auth_server
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Production: set to true (HTTPS-only)
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SESSION_HTTP_ONLY=true

# Monitoring — Telescope access control
# super_admin role always has access; list additional emails here (comma-separated)
TELESCOPE_ENABLED=true
TELESCOPE_ALLOWED_EMAILS=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# OIDC
OIDC_ISSUER=
OIDC_ID_TOKEN_TTL=60

# Hotsms SMS Gateway (production credentials should be set via Admin Settings panel, not here)
HOTSMS_ENABLED=true
HOTSMS_USERNAME=
HOTSMS_PASSWORD=
HOTSMS_SENDER=
HOTSMS_API_URL=http://hotsms.ps
HOTSMS_TIMEOUT=10
HOTSMS_COUNTRY_CODE=970

# Client Systems Redirect URIs (set per environment)
SYSTEM_A_REDIRECT_URI=http://localhost:8001/auth/callback
SYSTEM_B_REDIRECT_URI=http://localhost:8002/auth/callback
SYSTEM_C_REDIRECT_URI=http://localhost:8003/auth/callback
SYSTEM_D_REDIRECT_URI=http://localhost:8004/auth/callback
SYSTEM_E_REDIRECT_URI=http://localhost:8005/auth/callback

SYSTEM_A_URL=http://localhost:8001
SYSTEM_B_URL=http://localhost:8002
SYSTEM_C_URL=http://localhost:8003
SYSTEM_D_URL=http://localhost:8004
SYSTEM_E_URL=http://localhost:8005
